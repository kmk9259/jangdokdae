# Database (Neon Postgres)
DATABASE_URL=

# LLM API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=

# LLM
LLM_MODEL=gemini-3.1-flash-lite
MAIN_MODEL=gemini-3-flash-preview
LLM_THINKING_LEVEL=medium
LLM_TIMEOUT_SECONDS=600
LLM_TRANSPORT_MAX_RETRIES=2
LANGSMITH_PROJECT=issue-docent

# Gemini Vertex AI (선택 — Vertex AI 사용 시)
GEMINI_USE_VERTEX=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-northeast3
VERTEX_MODEL=

# Embedding
EMBED_MODEL=jhgan/ko-sroberta-multitask

# DART API Key
OPENDART_API_KEY=

# KRX 로그인
KRX_ID=
KRX_PW=

# OAuth (소셜 로그인)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT
JWT_SECRET=

# API 서버
CLIENT_URL=http://localhost:3000
