# Database (Neon Postgres)
DATABASE_URL=

# LLM API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=

# LLM
LLM_MODEL=gemini-3.1-flash-lite
MAIN_MODEL=gemini-3-flash-preview
LLM_THINKING_LEVEL=medium
LLM_TIMEOUT_SECONDS=600
LLM_TRANSPORT_MAX_RETRIES=2
LANGSMITH_PROJECT=issue-docent

# Vertex AI (Google Cloud 크레딧 적용)
# credentials/vertex_key.json 에 서비스 계정 키 파일 저장 후 설정
GOOGLE_APPLICATION_CREDENTIALS=credentials/vertex_key.json
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-northeast3
VERTEX_MODEL=gemini-2.5-flash

# Embedding
EMBED_MODEL=jhgan/ko-sroberta-multitask

# DART API Key
OPENDART_API_KEY=

# KRX 로그인
KRX_ID=<KRX 로그인 ID>
KRX_PW=<KRX 로그인 비밀번호>

# OAuth (소셜 로그인)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT
JWT_SECRET=

# API 서버
CLIENT_URL=http://localhost:3000
